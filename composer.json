{
    "name": "laikait/barcode-generator",
    "description": "A lightweight PHP barcode generator library supporting multiple formats with SVG and PNG output.",
    "type": "library",
    "keywords": ["barcode", "qrcode", "ean", "code128", "code39", "svg", "png", "laika"],
    "license": "MIT",
    "authors": [
        {
            "name": "Laika",
            "email": "hello@laika.dev"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Laika\\Barcode\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laika\\Barcode\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
